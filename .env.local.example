# Copy this file to .env.local and fill in your values

# HighLevel Webhook URL (get from GHL > Settings > Integrations > Webhooks)
HIGHLEVEL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID_HERE/webhook-trigger/YOUR_TRIGGER_ID

# Google Sheets (optional — leave blank to use built-in mock data)
# Steps: Google Cloud Console > APIs > Sheets API > Service Account > Download JSON key
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Your agent info (shown on About page and footer)
NEXT_PUBLIC_AGENT_NAME="Your Name"
NEXT_PUBLIC_AGENT_PHONE="(801) 555-0100"
NEXT_PUBLIC_AGENT_EMAIL="you@example.com"
NEXT_PUBLIC_AGENT_BROKERAGE="Your Brokerage"
NEXT_PUBLIC_AGENT_LICENSE="SA12345678"
